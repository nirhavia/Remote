<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC0F0F1A"
    android:padding="6dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="YES שלט"
        android:textColor="#E94560"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="4dp"/>

    <!-- שורה עליונה: CH+  CH-  V+  V-  OK  BACK -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="3dp">
        <Button android:id="@+id/w_ch_up"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:text="CH+" android:textSize="8sp" android:textColor="#FFF"
            android:background="#1E2030" android:layout_margin="1dp" android:padding="0dp"/>
        <Button android:id="@+id/w_ch_down"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:text="CH-" android:textSize="8sp" android:textColor="#FFF"
            android:background="#1E2030" android:layout_margin="1dp" android:padding="0dp"/>
        <Button android:id="@+id/w_vol_up"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:text="V+" android:textSize="10sp" android:textColor="#FFF"
            android:background="#1E2030" android:layout_margin="1dp" android:padding="0dp"/>
        <Button android:id="@+id/w_vol_down"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:text="V-" android:textSize="10sp" android:textColor="#FFF"
            android:background="#1E2030" android:layout_margin="1dp" android:padding="0dp"/>
        <Button android:id="@+id/w_ok"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:text="OK" android:textSize="10sp" android:textColor="#FFF" android:textStyle="bold"
            android:background="#E94560" android:layout_margin="1dp" android:padding="0dp"/>
        <Button android:id="@+id/w_back"
            android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
            android:text="&#x2190;" android:textSize="13sp" android:textColor="#CCC"
            android:background="#1E2030" android:layout_margin="1dp" android:padding="0dp"/>
    </LinearLayout>

    <!-- ספרות 1-3 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/w1"
            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="1" android:textSize="14sp" android:textColor="#FFF" android:textStyle="bold"
            android:background="#252840" android:layout_margin="1dp" android:padding="0dp"/>
        <Button android:id="@+id/w2"
            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="2" android:textSize="14sp" android:textColor="#FFF" android:textStyle="bold"
            android:background="#252840" android:layout_margin="1dp" android:padding="0dp"/>
        <Button android:id="@+id/w3"
            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="3" android:textSize="14sp" android:textColor="#FFF" android:textStyle="bold"
            android:background="#252840" android:layout_margin="1dp" android:padding="0dp"/>
    </LinearLayout>

    <!-- ספרות 4-6 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/w4"
            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="4" android:textSize="14sp" android:textColor="#FFF" android:textStyle="bold"
            android:background="#252840" android:layout_margin="1dp" android:padding="0dp"/>
        <Button android:id="@+id/w5"
            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="5" android:textSize="14sp" android:textColor="#FFF" android:textStyle="bold"
            android:background="#252840" android:layout_margin="1dp" android:padding="0dp"/>
        <Button android:id="@+id/w6"
            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="6" android:textSize="14sp" android:textColor="#FFF" android:textStyle="bold"
            android:background="#252840" android:layout_margin="1dp" android:padding="0dp"/>
    </LinearLayout>

    <!-- ספרות 7-9 -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/w7"
            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="7" android:textSize="14sp" android:textColor="#FFF" android:textStyle="bold"
            android:background="#252840" android:layout_margin="1dp" android:padding="0dp"/>
        <Button android:id="@+id/w8"
            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="8" android:textSize="14sp" android:textColor="#FFF" android:textStyle="bold"
            android:background="#252840" android:layout_margin="1dp" android:padding="0dp"/>
        <Button android:id="@+id/w9"
            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="9" android:textSize="14sp" android:textColor="#FFF" android:textStyle="bold"
            android:background="#252840" android:layout_margin="1dp" android:padding="0dp"/>
    </LinearLayout>

    <!-- שורה תחתונה: MUTE  0  LAST -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/w_mute"
            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="MUTE" android:textSize="8sp" android:textColor="#AAA"
            android:background="#1E2030" android:layout_margin="1dp" android:padding="0dp"/>
        <Button android:id="@+id/w0"
            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="0" android:textSize="14sp" android:textColor="#FFF" android:textStyle="bold"
            android:background="#252840" android:layout_margin="1dp" android:padding="0dp"/>
        <Button android:id="@+id/w_last_ch"
            android:layout_width="0dp" android:layout_height="36dp" android:layout_weight="1"
            android:text="&#8617;" android:textSize="14sp" android:textColor="#E94560"
            android:background="#1E2030" android:layout_margin="1dp" android:padding="0dp"/>
    </LinearLayout>

</LinearLayout>
